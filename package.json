{
  "name": "unison-engine",
  "displayName": "Unison Engine",
  "description": "Unison Engine Script Developer Extension - 提供API文档、代码补全、悬停提示等功能",
  "version": "0.1.4",
  "publisher": "ExRFy",
  "icon": "UnsLogo.png",
  "license": "BSD-3-Clause",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:python",
    "workspaceContains:**/unison.xml",
    "workspaceContains:**/*.py"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "snippets": [
      {
        "language": "python",
        "path": "./snippets/unison-snippets.json"
      }
    ],
    "commands": [
      {
        "command": "unison-engine.showModuleDoc",
        "title": "Unison: 显示模块文档"
      },
      {
        "command": "unison-engine.createSceneScript",
        "title": "Unison: 创建场景脚本"
      },
      {
        "command": "unison-engine.createInitScript",
        "title": "Unison: 创建初始化脚本"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "unison-engine.showModuleDoc",
          "group": "unison",
          "when": "editorLangId == python"
        }
      ]
    },
    "configuration": {
      "title": "Unison Engine",
      "properties": {
        "unisonEngine.enableAutoCompletion": {
          "type": "boolean",
          "default": true,
          "description": "启用 Unison API 自动补全"
        },
        "unisonEngine.showSignatureHelp": {
          "type": "boolean",
          "default": true,
          "description": "显示函数签名帮助"
        },
        "unisonEngine.moduleDocsLanguage": {
          "type": "string",
          "default": "zh-CN",
          "enum": ["zh-CN", "en-US"],
          "description": "模块文档语言"
        }
      }
    },
    "keybindings": [
      {
        "command": "unison-engine.showModuleDoc",
        "key": "ctrl+shift+u",
        "mac": "cmd+shift+u",
        "when": "editorTextFocus && editorLangId == python"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}